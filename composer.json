{
    "name": "graingenes/ggblast-plugin",
    "description": "JBrowse BLAST plugin with PHP API",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=7.4"
    },
    "autoload": {
        "psr-4": {
            "GGBlast\\": "blast/lib/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "php simple-test.php",
        "lint": "find blast -name '*.php' -exec php -l {} \\;"
    }
}
